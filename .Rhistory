library(tidyverse)
# Below you are loading 2 new packages:shiny + shinydashboard.
# Install them once, then comment out the install command.
# install.packages("shiny")
library(shiny)
# install.packages("shinydashboard")
library(shinydashboard)
# This should load the datasets:
# experience (123 by 11) and quiz (2423 by 13)
load("info4100.proj.dashboard.rda")
#######################################
####### BEGIN INPUT: Question 3 #######
#######################################
# Example of a tab (i.e. page)
instructor_dash = tabItem(
tabName = "instructor",
h2("Instructor Dashboard"),
# Dynamic infoBoxes
fluidRow(
infoBoxOutput("inst.info1"),
infoBoxOutput("inst.info2")
),
# Any visualization
fluidRow(
box(
title = "Box 1",
plotOutput("inst.plot1", height = 250)
),
box(
title = "Box 2",
plotOutput("inst.plot2", height = 250)
)
)
)
# Another empty tab
student_dash = tabItem(
tabName = "student",
h2("Student Dashboard")
)
#######################################
#######################################
#######################################
####### BEGIN INPUT             #######
#######################################
# combine quiz and experience datasets by STUDENT_KEY and YEAR
df <- left_join(quiz, experience, by = c("STUDENT_KEY", "YEAR"))
head(df)
# creates dataframe grouped by lecture
# for some lectures, there are multiple iClicker sessions
# the grouping combines the sessions into one per lecture
df_by_lecture <- df %>%
group_by(STUDENT_KEY,
ACAD_DATE_KEY,
YEAR,
QUIZ_NUMBER,
ATTENDED,
PROG,
DATABASE_SCORE,
SQL_SCORE,
PROGRAMING_SCORE,
STORED_PROC_SCORE,
ETL_SCORE,
DATA_VIS_SCORE,
REQUIREMENT_GATHER_SCORE,
SKILL_SURVEY_SCORE) %>%
summarise(SESSION_NUMBER = min(SESSION_NUMBER),
TOTAL_POSSIBLE_CLICKER = sum(TOTAL_POSSIBLE_CLICKER),
TOTAL_COMPLETED_CLICKER = sum(TOTAL_COMPLETED_CLICKER),
COMPLETED_Q_CLICKER = sum(COMPLETED_Q_CLICKER),
CORRECT_Q_CLICKER = sum(CORRECT_Q_CLICKER),
COMPLETED_T_CLICKER = sum(COMPLETED_T_CLICKER),
AVG_T_CLICKER = mean(AVG_T_CLICKER),
QUIZ_SCORE = mean(QUIZ_SCORE, na.rm = TRUE)) %>%
arrange(STUDENT_KEY, ACAD_DATE_KEY)
# since we combined sessions where there were multiple per lecture,
# let's add a field to indicate each lecture by number
# LECTURE_NUMBER
df_by_lecture <- df_by_lecture %>%
group_by(STUDENT_KEY) %>%
arrange(SESSION_NUMBER, .by_group = TRUE) %>%
mutate(LECTURE_NUMBER = row_number()) %>%
ungroup()
head(df_by_lecture)
#######################################
#######################################
server = function(input, output) {
#######################################
####### BEGIN INPUT: Question 4 #######
#######################################
output$inst.info1 = renderInfoBox({
infoBox("Students total",
length(unique(quiz$STUDENT_KEY)),
icon = icon("list"), color = "purple")
})
output$inst.info2 = renderInfoBox({
infoBox("Attendance",
paste0(round(100 * mean(quiz$ATTENDED)), "%"),
icon = icon("list"), color = "yellow")
})
output$inst.plot1 = renderPlot({
hist(quiz$QUIZ_SCORE)
})
output$inst.plot2 = renderPlot({
# I'm giving you three examples here
# only the last one will be displayed
# but you can try out each one.
# As you can see, using ggplot allows you to
# make much better-looking visualizations.
# simple
hist(quiz$TOTAL_COMPLETED_CLICKER)
# using ggplot
ggplot(quiz, aes(TOTAL_COMPLETED_CLICKER)) +
geom_histogram()
# using ggplot to make it clearer
ggplot(quiz, aes(x = TOTAL_COMPLETED_CLICKER)) +
geom_density(fill="gray") + # makes the density line and gray fill
labs(x = "Completed Clicker Questions", y = "Density") + # change axis labels
theme_classic() # to use white background
})
#######################################
#######################################
}
# create plots here to test before adding to dashboard
# to compare class attendance per lecture,
# i need to group the data by lecture
attendance_per_lecture <- df_by_lecture %>%
group_by(LECTURE_NUMBER) %>%
summarise(TOTAL_AVG_ATTENDANCE = mean(ATTENDED))
avg_skill_survery_score <- mean(df_by_lecture$SKILL_SURVEY_SCORE, na.rm = TRUE)
less_skilled_attendance_per_lecture <- df_by_lecture %>%
filter(SKILL_SURVEY_SCORE < avg_skill_survery_score) %>%
group_by(LECTURE_NUMBER) %>%
summarise(LESS_SKILLED_AVG_ATTENDANCE = mean(ATTENDED))
more_skilled_attendance_per_lecture <- df_by_lecture %>%
filter(SKILL_SURVEY_SCORE >= avg_skill_survery_score) %>%
group_by(LECTURE_NUMBER) %>%
summarise(MORE_SKILLED_AVG_ATTENDANCE = mean(ATTENDED))
attendance_per_lecture <- attendance_per_lecture %>%
inner_join(less_skilled_attendance_per_lecture) %>%
inner_join(more_skilled_attendance_per_lecture)
attendance_per_lecture <- attendance_per_lecture %>%
pivot_longer(cols = c(TOTAL_AVG_ATTENDANCE,
LESS_SKILLED_AVG_ATTENDANCE,
MORE_SKILLED_AVG_ATTENDANCE),
names_to = "SKILL_LEVEL",
values_to = "AVG_ATTENDANCE")
# lineplot of class attendance each week given different prior experience levels
ggplot(attendance_per_lecture %>%
filter(LECTURE_NUMBER < 21),
aes(x = LECTURE_NUMBER,
y = AVG_ATTENDANCE,
color = SKILL_LEVEL)) +
geom_point(size = 2) +
geom_line(size = 1.5) +
scale_color_manual(
values = c(
"TOTAL_AVG_ATTENDANCE" = "#FFCBE1",
"LESS_SKILLED_AVG_ATTENDANCE" = "#F9E1A8",
"MORE_SKILLED_AVG_ATTENDANCE" = "#D6E5BD"
),
labels = c(
"TOTAL_AVG_ATTENDANCE" = "All Students",
"LESS_SKILLED_AVG_ATTENDANCE" = "Skills Below Average",
"MORE_SKILLED_AVG_ATTENDANCE" = "Skills Above Average"
),
name = "Skill Level"
) +
theme_classic()
#######################################
### This code creates the dashboard ###
#######################################
# Here we set up the Header of the dashboard
dhead = dashboardHeader(title = "Clicker Dashboard")
# Here set up the sidebar which has links to two pages
dside = dashboardSidebar(
sidebarMenu(
menuItem("Instructor View", tabName = "instructor", icon = icon("dashboard")),
menuItem("Student View", tabName = "student", icon = icon("th"))
)
)
# Here we set up the body of the dashboard
dbody = dashboardBody(
tabItems(
student_dash,
instructor_dash
)
)
# Combining header, sidebar, and body
ui = dashboardPage(dhead, dside, dbody)
# Generating a local instance of your dashboard
shinyApp(ui, server)
